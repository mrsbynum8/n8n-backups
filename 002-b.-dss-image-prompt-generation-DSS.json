        "parameters": {
          "jsCode": "const openaiResponse = $input.item.json.choices[0].message.content;\nlet prompts;\n\ntry {\n  prompts = JSON.parse(openaiResponse);\n} catch (e) {\n  const jsonMatch = openaiResponse.match(/```json\\s*([\\s\\S]*?)\\s*```/);\n  if (jsonMatch) {\n    prompts = JSON.parse(jsonMatch[1]);\n  } else {\n    throw new Error(\"Could not parse OpenAI response as JSON\");\n  }\n}\n\nconst videoName = $('Loop Over Topics').item.json.video_name;\nconst rowNumber = $('Loop Over Topics').item.json.row_number;\n\nreturn prompts.map((p, index) => ({\n  json: {\n    video_name: videoName,\n    image_number: String(index + 1).padStart(2, '0'),\n    filename: `${videoName}-${String(index + 1).padStart(2, '0')}.png`,\n    prompt: p.prompt,\n    status: 'pending',\n    topic_row_number: rowNumber\n  }\n}));"
        },
