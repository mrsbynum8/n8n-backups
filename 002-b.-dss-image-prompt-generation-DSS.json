        "jsCode": "return [{\n  json: {\n    video_name: $input.item.json.video_name,\n    topic: $input.item.json.topic,\n    image_count: 30,\n    row_number: $input.item.json.row_number\n  }\n}];"
      },
      "id": "e8db7453-fc20-4cba-b8b8-aa9f6821c157",
