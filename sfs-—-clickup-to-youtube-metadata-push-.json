      "id": "d79ac004-cd7e-4c4c-b5d2-42ab3b2fc4b5",
      "name": "Is Status 'Push to YouTube'?",
      "type": "n8n-nodes-base.if",
      "position": [
        256,
        272
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const fields = $input.first().json.custom_fields;\n\nconst getField = (id) => {\n  const f = fields.find(f => f.id === id);\n  return (f && f.value !== undefined && f.value !== null) ? f.value : null;\n};\n\nconst tagsRaw = getField('3a9c232c-2f8e-4916-ab50-392103a71491');\nconst tagsString = Array.isArray(tagsRaw)\n  ? tagsRaw.map(t => t.trim()).join(',')\n  : (tagsRaw ? tagsRaw.split(',').map(t => t.trim()).join(',') : '');\n\nconst publishedUrl = getField('cf96eec7-0104-4cf4-8c19-70674f44bb64');\nconst videoIdMatch = publishedUrl ? publishedUrl.match(/youtu\\.be\\/([a-zA-Z0-9_-]+)/) : null;\nconst videoId = videoIdMatch ? videoIdMatch[1] : null;\n\nconst scheduledRaw = getField('596b25a4-62ee-4640-a17a-44b68b5233e0');\nlet publishAt = null;\nif (scheduledRaw) {\n  const d = new Date(parseInt(scheduledRaw));\n  d.setUTCHours(23, 8, 0, 0);\n  publishAt = d.toISOString();\n}\n\nconst thumbnailUrl = $input.first().json.attachments?.[0]?.url || null;\n\nreturn [{\n  json: {\n    yt_title:       getField('3aa0126f-e0d2-41ff-bbe7-a0ff6bf25ab7'),\n    yt_description: getField('af715d19-ad93-4a0e-a73c-40c712aaaae3'),\n    yt_tags:        tagsString,\n    yt_video_id:    videoId,\n    publish_at:     publishAt,\n    thumbnail_url:  thumbnailUrl,\n    task_id:        $input.first().json.id\n  }\n}];"
      },
